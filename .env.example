# Database
DATABASE_URL="postgresql://..."

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-key-here"

# OAuth Providers
GOOGLE_ID="your-google-client-id"
GOOGLE_SECRET="your-google-client-secret"
FACEBOOK_ID="your-facebook-app-id"
FACEBOOK_SECRET="your-facebook-app-secret"

# TMDB (The Movie Database) API
# Get your free API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY="your-tmdb-api-key"

# Google Places API (restaurant search)
# Enable the Places API in Google Cloud Console and create an API key
GOOGLE_PLACES_API_KEY="your-google-places-api-key"

# Codecov — upload token for CI coverage reports and API access
# Get your token at: https://app.codecov.io/gh/navybrmi/clique/settings
# Also add this as a GitHub repository secret named CODECOV_TOKEN
CODECOV_TOKEN="your-codecov-token"
